# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# IDE
.idea/

# Claude Code local settings
.claude/settings.local.json

# Python bytecode from Claude skills
.claude/skills/**/__pycache__/
.claude/skills/**/*.pyc

# Playwright MCP runtime artifacts (yml snapshots, console logs)
.playwright-mcp/

# Claude Code scheduled task lockfile
.claude/scheduled_tasks.lock

# vercel
.vercel

# Supabase CLI local cache (created by `npx supabase --version` etc.)
supabase/.temp/

# graphify regenerable caches — graph.html / graph.json / GRAPH_REPORT.md
# ARE tracked (they're evidence for the TFG audit trail), these aren't.
graphify-out/cache/
graphify-out/node_modules/
.graphify_*.py
.graphify_*.json
.graphify_*.txt
.graphify_python

# typescript
*.tsbuildinfo
next-env.d.ts

# LaTeX (tfg/) — aux files only; keep .tex, .bib, .pdf (final output if compiled locally)
tfg/**/*.aux
tfg/**/*.log
tfg/**/*.out
tfg/**/*.toc
tfg/**/*.lof
tfg/**/*.lot
tfg/**/*.bbl
tfg/**/*.bcf
tfg/**/*.blg
tfg/**/*.fdb_latexmk
tfg/**/*.fls
tfg/**/*.run.xml
tfg/**/*.synctex.gz
tfg/**/*.synctex.gz(busy)
tfg/main.pdf
