      "text": "Tens tota la raó. Si volem un \"Segon Cervell\", la IA ha de ser la protagonista, no un accessori.\n\nFer que l\u0027estructura s\u0027assembli a **ChatGPT** o **Claude** (Panell fix a l\u0027esquerra + Contingut a la dreta) és la millor decisió de UX per a aquest tipus d\u0027app.\n\nAnem a transformar l\u0027estructura en un **Layout de Dos Panells**.\n\n### 🛠️ Pas 1: Transformar el `ChatSidebar` (Adéu Pop-up)\n\nModificarem el component perquè deixi de ser un `Sheet` (modal) i passi a ser un `aside` (columna fixa).\n\nEdita `src/components/chat/chat-sidebar.tsx`:\n*   Eliminem `Sheet`, `SheetContent`, etc.\n*   Fem que sigui un contenidor `flex` d\u0027alçada completa.\n*   Carreguem els xats automàticament al principi (`useEffect` sense dependència `isOpen`).\n\n```typescript\n\u0027use client\u0027\n\nimport { useState, useEffect } from \u0027react\u0027\nimport { Button } from \u0027@/components/ui/button\u0027\nimport { Input } from \u0027@/components/ui/input\u0027\nimport { ScrollArea } from \u0027@/components/ui/scroll-area\u0027\nimport { Plus, History, Send, Bot } from \u0027lucide-react\u0027\nimport { useChat } from \u0027@ai-sdk/react\u0027\nimport ReactMarkdown from \u0027react-markdown\u0027\nimport { createClient } from \u0027@/lib/supabase/client\u0027\nimport { cn } from \u0027@/lib/utils\u0027\nimport remarkGfm from \u0027remark-gfm\u0027\n\nexport function ChatSidebar({ userId }: { userId: string }) {\n  // Ja no necessitem isOpen, sempre està obert\n  const [chatId, setChatId] \u003d useState\u003cstring | null\u003e(null)\n  const [chatList, setChatList] \u003d useState\u003cany[]\u003e([])\n  const [input, setInput] \u003d useState(\u0027\u0027)\n  \n  const supabase \u003d createClient()\n\n  const { messages, status, sendMessage, setMessages } \u003d useChat({\n    onFinish: () \u003d\u003e {\n       // Opcional: Refrescar llista si és el primer missatge\n       if (!chatId) fetchChats()\n    }\n  })\n\n  const isLoading \u003d status \u003d\u003d\u003d \u0027submitted\u0027 || status \u003d\u003d\u003d \u0027streaming\u0027\n\n  const fetchChats \u003d async () \u003d\u003e {\n    const { data } \u003d await supabase.from(\u0027chats\u0027).select(\u0027*\u0027).order(\u0027created_at\u0027, { ascending: false })\n    if (data) setChatList(data)\n  }\n\n  // 1. Carregar historial al muntar el component\n  useEffect(() \u003d\u003e {\n    fetchChats()\n  }, [])\n\n  const loadChat \u003d async (id: string) \u003d\u003e {\n    setChatId(id)\n    const { data } \u003d await supabase.from(\u0027messages\u0027).select(\u0027*\u0027).eq(\u0027chat_id\u0027, id).order(\u0027created_at\u0027, { ascending: true })\n    \n    if (data) {\n      const uiMessages \u003d data.map((m: any) \u003d\u003e ({\n        id: m.id,\n        role: m.role,\n        parts: [{ type: \u0027text\u0027, text: m.content }]\n      }))\n      setMessages(uiMessages as any)\n    }\n  }\n\n  const createNewChat \u003d async () \u003d\u003e {\n    setMessages([])\n    setInput(\u0027\u0027)\n    setChatId(null)\n    \n    const { data } \u003d await supabase.from(\u0027chats\u0027).insert({\n        user_id: userId,\n        title: \u0027Nova Conversa\u0027\n    }).select().single()\n\n    if (data) {\n        setChatId(data.id)\n        setChatList([data, ...chatList])\n        return data.id\n    }\n    return null\n  }\n\n  const handleSend \u003d async (e?: React.FormEvent) \u003d\u003e {\n    e?.preventDefault()\n    if (!input.trim()) return\n\n    let currentChatId \u003d chatId\n    if (!currentChatId) {\n        currentChatId \u003d await createNewChat()\n    }\n\n    const content \u003d input\n    setInput(\u0027\u0027) \n\n    await sendMessage(\n      { role: \u0027user\u0027, parts: [{ type: \u0027text\u0027, text: content }] },\n      { body: { chatId: currentChatId } }\n    )\n  }\n\n  return (\n    // CONTENIDOR PRINCIPAL (ASIDE)\n    // Amplada fixa de 400px (o w-1/3), alçada completa, vora dreta\n    \u003caside className\u003d\"w-[400px] flex flex-col border-r bg-background/50 backdrop-blur-xl h-full shadow-xl z-20\"\u003e\n      \n      {/* HEADER DEL XAT */}\n      \u003cdiv className\u003d\"p-4 border-b flex items-center justify-between bg-background/80\"\u003e\n        \u003cdiv className\u003d\"flex items-center gap-2 font-semibold text-primary\"\u003e\n          \u003cBot className\u003d\"h-5 w-5\" /\u003e\n          Synapse AI\n        \u003c/div\u003e\n        \u003cButton variant\u003d\"outline\" size\u003d\"sm\" onClick\u003d{createNewChat} className\u003d\"h-8\"\u003e\n          \u003cPlus className\u003d\"mr-2 h-3 w-3\" /\u003e Nou\n        \u003c/Button\u003e\n      \u003c/div\u003e\n\n      \u003cdiv className\u003d\"flex flex-1 overflow-hidden\"\u003e\n          {/* HISTORIAL (Barra estreta) */}\n          \u003cdiv className\u003d\"w-14 border-r bg-muted/10 flex flex-col items-center py-4 gap-2 overflow-y-auto hide-scrollbar\"\u003e\n              {chatList.map((chat) \u003d\u003e (\n                  \u003cButton \n                      key\u003d{chat.id} \n                      variant\u003d{chatId \u003d\u003d\u003d chat.id ? \"default\" : \"ghost\"} \n                      size\u003d\"icon\"\n                      className\u003d\"h-9 w-9 rounded-full transition-all hover:scale-110\"\n                      onClick\u003d{() \u003d\u003e loadChat(chat.id)}\n                      title\u003d{new Date(chat.created_at).toLocaleDateString()}\n                  \u003e\n                      \u003cHistory className\u003d\"h-4 w-4\" /\u003e\n                  \u003c/Button\u003e\n              ))}\n          \u003c/div\u003e\n\n          {/* ZONA DE MISSATGES */}\n          \u003cdiv className\u003d\"flex-1 flex flex-col h-full bg-background/50\"\u003e\n              \u003cScrollArea className\u003d\"flex-1 p-4\"\u003e\n                  {messages.length \u003d\u003d\u003d 0 ? (\n                       \u003cdiv className\u003d\"h-full flex flex-col items-center justify-center text-center p-6 opacity-60\"\u003e\n                          \u003cBot className\u003d\"h-10 w-10 mb-3 text-muted-foreground/50\" /\u003e\n                          \u003cp className\u003d\"text-sm font-medium\"\u003eSóc el teu segon cervell.\u003c/p\u003e\n                          \u003cp className\u003d\"text-xs text-muted-foreground\"\u003ePregunta sobre les teves notes.\u003c/p\u003e\n                       \u003c/div\u003e\n                  ) : (\n                      \u003cdiv className\u003d\"flex flex-col gap-6 pb-4\"\u003e\n                          {messages.map((m) \u003d\u003e (\n                              \u003cdiv key\u003d{m.id} className\u003d{cn(\n                                  \"flex w-full\",\n                                  m.role \u003d\u003d\u003d \u0027user\u0027 ? \"justify-end\" : \"justify-start\"\n                              )}\u003e\n                                  \u003cdiv className\u003d{cn(\n                                      \"max-w-[90%] rounded-2xl p-3 text-sm shadow-sm\",\n                                      m.role \u003d\u003d\u003d \u0027user\u0027 \n                                          ? \"bg-primary text-primary-foreground rounded-tr-none\" \n                                          : \"bg-white dark:bg-muted border rounded-tl-none\"\n                                  )}\u003e\n                                      \u003cdiv className\u003d\"prose prose-sm dark:prose-invert break-words leading-relaxed\"\u003e\n                                          {m.parts ? (\n                                              m.parts.map((p, i) \u003d\u003e p.type \u003d\u003d\u003d \u0027text\u0027 \u0026\u0026 (\n                                                \u003cReactMarkdown key\u003d{i} remarkPlugins\u003d{[remarkGfm]}\u003e\n                                                  {p.text}\n                                                \u003c/ReactMarkdown\u003e\n                    