s pot fallar o no tornar res.\n  // Podem afegir un check de seguretat aquí, però l\u0027RPC sol aguantar-ho.\n  const { data: similarNotes } \u003d await supabase.rpc(\"match_notes\", {\n    query_embedding: queryEmbedding,\n    match_threshold: 0.3,\n    match_count: 5,\n  });\n\n  const ragContext \u003d\n    similarNotes?.map((note: any) \u003d\u003e note.content).join(\"\\n\\n\") || \"\";\n\n  const systemPrompt \u003d `\n     You are a helpful assistant for a \"Second Brain\" app.\n     \n     STANDARD CONTEXT (From Vector Search):\n     ${ragContext}\n     \n     INSTRUCTIONS:\n     - Use the provided tools if the user specifically asks to filter by tags.\n     - Otherwise, answer based on the standard context provided above.\n     - Answer in the user\u0027s language.\n   `;\n\n  // 2. Definició de l\u0027esquema de l\u0027eina\n  const GetNotesByTagSchema \u003d z.object({\n    tag: z.string().describe(\u0027The tag to filter by (e.g., \"Ideas\", \"Work\")\u0027),\n  });\n\n  // 3. Generar i Guardar\n  const result \u003d streamText({\n    // ✅ ACTUALITZACIÓ: Usem un model estable i potent\n    model: google(\"gemini-1.5-flash\"), \n    system: systemPrompt,\n    messages: convertToCoreMessages(messages),\n\n    // ✅ TOOLS DEFINITION (AI SDK v5+)\n    tools: {\n      getNotesByTag: tool({\n        description: \"Get a list of notes that have a specific tag.\",\n        inputSchema: GetNotesByTagSchema, // ✅ Correcte per SDK v5\n        execute: async ({ tag }: z.infer\u003ctypeof GetNotesByTagSchema\u003e) \u003d\u003e {\n          console.log(`🤖 Searching tag: \u0027${tag}\u0027`);\n          const { data, error } \u003d await supabase\n            .from(\"notes\")\n            .select(\"content, created_at\")\n            .contains(\"tags\", [tag])\n            .limit(10);\n\n          if (error) return `Error: ${error.message}`;\n          if (!data?.length) return `No notes found with tag \u0027${tag}\u0027.`;\n          return JSON.stringify(data);\n  