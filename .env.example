# Supabase - Get from: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (server-only, bypasses RLS). Used by the MCP PoC route.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AI - Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Anthropic (chat model: claude-haiku-4-5)
ANTHROPIC_API_KEY=your-anthropic-api-key

# MCP PoC (Week 1). Hardcoded Bearer token + user_id until Phase 2 OAuth passthrough.
MCP_POC_TOKEN=generate-a-long-random-string
MCP_POC_USER_ID=your-supabase-auth-user-uuid
