# Supabase - Get from: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (server-only, bypasses RLS). Reserved for background agents
# (Week 4: Supabase Edge Functions with pg_cron). NOT used by the MCP server
# route; that path now does JWT passthrough + RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AI - Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# Anthropic (chat model: claude-haiku-4-5)
ANTHROPIC_API_KEY=your-anthropic-api-key
